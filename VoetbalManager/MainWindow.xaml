<Window x:Class="VoetbalManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoetbalManager"
        mc:Ignorable="d"       
       
        Title="MainWindow" Height="450" Width="800" >

    <Grid>

        <TabControl>
            <TabItem Header="Manager">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72*"/>
                        <ColumnDefinition Width="127*"/>
                        <ColumnDefinition Width="199*"/>
                        <ColumnDefinition Width="199*"/>
                        <ColumnDefinition Width="199*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.ColumnSpan="5" Source="/voetbalmanager-stadion.jpg" Stretch="UniformToFill"/>
                    <Rectangle Grid.Column="4">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.6">
                                <GradientStop Color="Black" Offset="0.5" />
                                <GradientStop Color="Transparent" Offset="0.8" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <StackPanel Grid.Column="0" Orientation="Vertical" Grid.ColumnSpan="2">
                        <TextBox x:Name="teamNameTextBox" Margin="20"/>
                        <Button x:Name="addTeamButton" Content="Voeg team toe" Margin="20" Click="OnAddTeamButtonClicked" />
                        <ComboBox x:Name="teamsComboBox" Margin="20,10,20,10" SelectionChanged="OnTeamSelectionChanged" />
                        <TextBlock x:Name="teaminfoTextBlock" Margin="20,10,20,10" Foreground="White"/>

                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Vertical" Grid.ColumnSpan="2" Margin="126,0,0,0" >
                        <TextBlock Text="Voornaam" Margin="20,20,20,10" Foreground="White"/>
                        <TextBlock Text="Achternaam" Margin="20,10,20,10" Foreground="White"/>
                        <TextBlock Text="Positie" Margin="20,10,20,10" Foreground="White"/>
                        <TextBlock Text="Rugnummer" Margin="20,10,20,10" Foreground="White"/>
                        <TextBlock Text="Aantal Doelpunten" Margin="20,10,20,10" Foreground="White"/>
                        <TextBlock Text="Is Kapitein" Margin="20,10,20,10" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Grid.ColumnSpan="2" Margin="0,0,198,0">
                        <TextBox x:Name="firstNameTextbox" Margin="20,20,20,10" />
                        <TextBox x:Name="lastNameTextbox" Margin="20,10,20,10" />
                        <TextBox x:Name="positionTextbox" Margin="20,10,20,10" />
                        <TextBox x:Name="jerseyNumberTextbox" Margin="20,10,20,10" />
                        <TextBox x:Name="numberOfGoalsTextbox" Margin="20,10,20,10" />
                        <CheckBox x:Name="isCaptainCheckBox" Content="is kapitein" Foreground="White"  Margin="20,10,20,10" />
                        <Button x:Name="addPlayerButton" Content="Voeg speler toe" Margin="20,10,20,10" Click="OnAddPlayerButtonClicked" />
                    </StackPanel>
                    <DockPanel Grid.Column="4">
                        <Button DockPanel.Dock="Bottom" x:Name="removePlayerButton" Content="Verwijder speler" Margin="20,10,20,10" Click="OnRemovePlayerButtonClicked" />
                        <TextBox DockPanel.Dock="Bottom" x:Name="playerinfoTextBox" Margin="10,10,10,10" Height="120" Opacity="0.7"/>
                        <ListBox DockPanel.Dock="Top" x:Name="footballersListBox" Margin="10,10,10,10" Height="220" Background="Transparent" Foreground="White" SelectionChanged="OnFootballersListBoxSelectionChanged" />
                    </DockPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Planner">
                <DockPanel Background="Bisque">
                    <StackPanel x:Name="newMatchStackPanel"  DockPanel.Dock="Left" Margin="5">
                        <WrapPanel Margin="5" Orientation="Horizontal">
                            <Label Content="Datum:" MinWidth="80"/>
                            <DatePicker x:Name="matchDatePicker" Width="100" SelectedDateChanged="OnMatchDatePickerDateChanged"/>
                        </WrapPanel>
                        <WrapPanel Margin="5" Orientation="Horizontal">
                            <Label Content="Home:" MinWidth="80"/>
                            <ComboBox x:Name="homeComboBox" Width="100" SelectionChanged="OnHomeSelectionChanged"/>
                        </WrapPanel>
                        <WrapPanel Margin="5" Orientation="Horizontal">
                            <Label Content="Visitor:" MinWidth="80"/>
                            <ComboBox x:Name="visitorComboBox" Width="100" SelectionChanged="OnVisitorSelectionChanged"/>
                        </WrapPanel>
                        <WrapPanel Margin="5" Orientation="Horizontal">
                            <Label Content="Location:" MinWidth="80"/>
                            <ComboBox x:Name="stadiumComboBox" Width="100"/>
                        </WrapPanel>
                        <WrapPanel>
                        <Button x:Name="newMatchButton" MinWidth="180" Content="Toevoegen" Margin="5,10,5,5" IsEnabled="False" Click="OnNewMatchButtonClicked"/>
                        </WrapPanel>
                    </StackPanel>
                    <Button x:Name="toggleButton" DockPanel.Dock="Left" Width="30" >
                        <Image Source="/Images/arrow-right.png"/>
                    </Button>
                    <Calendar x:Name="dateselectorCalendar" DockPanel.Dock="Top" SelectedDatesChanged="OnDateSelectorDateChanged" />
                    <ListBox x:Name="matchListBox" DockPanel.Dock="Bottom" Margin="10" MouseDoubleClick="OnMatchListBoxMouseDoubleClick"/>
                </DockPanel>
            </TabItem>
        </TabControl>


    </Grid>
</Window>
